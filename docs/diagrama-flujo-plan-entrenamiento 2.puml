@startuml

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontSize 14

skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #000000
    BorderThickness 2
}

skinparam arrow {
    Color #000000
    Thickness 2
}

title Flujo de Navegación - Plan de Entrenamiento

rectangle "Dashboard" as Dashboard
rectangle "Plan Entrenamiento" as Main
rectangle "Modal Plan Generado" as ModalPlan
rectangle "Modal Plan Anterior" as ModalHistory

Dashboard --> Main
Main --> Dashboard
Main --> ModalPlan
ModalPlan --> Main
Main --> ModalHistory
ModalHistory --> Main

@enduml
